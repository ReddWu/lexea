# Copy to .env.local (local dev) and set the same vars in Vercel (Project → Settings → Environment Variables).
# These are SERVER-ONLY — never prefixed with NEXT_PUBLIC, so the anon key never reaches the browser.

# Your InsForge project's oss_host (see .insforge/project.json)
INSFORGE_OSS_HOST=https://xxxxxxx.us-east.insforge.app

# The anon key (starts with anon_) — NOT the ik_ admin key
INSFORGE_ANON_KEY=anon_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: protect the site with a password. Leave unset/empty to make the site open.
APP_PASSWORD=
